# Supabase: Project Settings → Database → URI (use pooler if recommended).
# Example: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# Comma-separated origins for browser CORS (Vite default below).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Must match seeded tenant in migrations/001_core_tenant_chart_ingest.sql unless you add tenants.
DEFAULT_TENANT_ID=00000000-0000-4000-8000-000000000001

# Optional: if set, all /sync/* routes require Authorization: Bearer <this value>
SYNC_API_KEY=

# Required for POST /auth/login and for browser JWT access to /sync/* and /attachments/* when set.
# Generate a long random string for production.
JWT_SECRET=

# Access token lifetime in minutes (default 1440 = 24h).
# JWT_EXPIRE_MINUTES=1440

# URL the browser calls for dev presigned PUT targets (must match how you open the API).
PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Optional S3 / MinIO / R2 — install boto3 (`pip install -e ".[storage-s3]"`). When S3_BUCKET is set, presign uses S3.
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
