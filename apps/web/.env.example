# Copy to `.env` locally (not committed). Vite exposes only VITE_* to the client.
#
# Phase 7 — point the PWA at your FastAPI + Postgres (e.g. Supabase-backed API on localhost or HTTPS).
# VITE_SYNC_API_BASE=http://localhost:8000
# Tenant UUID header (optional when using JWT from login — server uses token tenant).
# VITE_SYNC_TENANT_ID=00000000-0000-4000-8000-000000000001
# API key for scripts / legacy clients when SYNC_API_KEY is set on server (browser uses JWT after login when JWT_SECRET is set).
# VITE_SYNC_API_KEY=your-server-SYNC_API_KEY-if-set
# Slug for POST /auth/login (must match tenants.slug in Postgres; seed default is "default").
# VITE_SYNC_TENANT_SLUG=default
