{
  "name": "ayekta-emr",
  "private": true,
  "version": "2.0.0",
  "description": "Ayekta EMR monorepo (web PWA + shared packages)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @ayekta/web",
    "api:dev": "cd apps/api && python -m uvicorn ayekta_api.main:app --reload --host 0.0.0.0 --port 8000",
    "build": "npm run build -w @ayekta/web",
    "preview": "npm run preview -w @ayekta/web",
    "lint": "npm run lint -w @ayekta/web",
    "predeploy": "npm run build",
    "deploy": "npm run deploy -w @ayekta/web"
  }
}
